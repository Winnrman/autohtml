  /* ── quick view panel ── */
  .quick-panel { flex-shrink: 0; width: 0; overflow: hidden; transition: width 0.28s ease; position: sticky; top: 57px; max-height: calc(100vh - 57px); overflow-y: auto; background: white; border-left: none; }
  .quick-panel.open { width: clamp(260px, 33vw, 480px); border-left: 1.5px solid #eee; }
  .qv-inner { display: flex; flex-direction: column; gap: 14px; padding: 20px; min-width: clamp(260px, 33vw, 480px); }
  .qv-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 10px; }
  .qv-title { font-size: 1rem; font-weight: 700; color: #1a1a1a; line-height: 1.3; flex: 1; }

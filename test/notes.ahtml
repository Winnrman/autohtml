<db type="sqlite">
  CREATE TABLE IF NOT EXISTS notes (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    title TEXT NOT NULL,
    body TEXT NOT NULL,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP
  );
</db>

<server lang="node">
app.get('/api/notes', (req, res) => {
  const notes = db.query('SELECT * FROM notes ORDER BY created_at DESC');
  res.json(notes);
});

app.post('/api/notes', (req, res) => {
  const { title, body } = req.body;
  if (!title || !body) {
    res.status(400).json({ error: 'title and body required' });
    return;
  }
  const result = db.run(
    'INSERT INTO notes (title, body) VALUES (?, ?)',
    [title, body]
  );
  const note = db.get('SELECT * FROM notes WHERE id = ?', [result.lastInsertRowid]);
  res.json(note);
});

app.delete('/api/notes', (req, res) => {
  db.run('DELETE FROM notes WHERE id = ?', [req.body.id]);
  res.json({ ok: true });
});
</server>

<client>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>notes</title>
</head>
<body>
  <div class="app">
    <div class="sidebar">
      <div class="sidebar-header">
        <h2>notes</h2>
        <button class="new-btn" onclick="showCompose()">+</button>
      </div>
      <ul id="note-list"></ul>
    </div>
    <div class="main">
      <div id="compose" class="compose hidden">
        <input id="title-input" type="text" placeholder="Title">
        <textarea id="body-input" placeholder="Write something..."></textarea>
        <div class="compose-actions">
          <button class="cancel-btn" onclick="hideCompose()">cancel</button>
          <button class="save-btn" onclick="saveNote()">save</button>
        </div>
      </div>
      <div id="note-view" class="note-view hidden">
        <div class="note-view-header">
          <h1 id="view-title"></h1>
          <span id="view-date"></span>
        </div>
        <div id="view-body"></div>
      </div>
      <div id="empty-state" class="empty-state">
        <p>no notes yet</p>
        <button onclick="showCompose()">write one</button>
      </div>
    </div>
  </div>

  <script>
    let notes = [];

    async function loadNotes(selectId = null) {
      notes = await fetch('/api/notes').then(r => r.json());
      renderList();
      if (notes.length === 0) {
        document.getElementById('note-view').classList.add('hidden');
        document.getElementById('empty-state').classList.remove('hidden');
      } else {
        document.getElementById('empty-state').classList.add('hidden');
        const target = selectId ? notes.find(n => n.id === selectId) : null;
        viewNote(target ? target.id : notes[0].id);
      }
    }

    console.log('nigga');


    function renderList() {
      const list = document.getElementById('note-list');
      list.innerHTML = notes.map(n => `
        <li class="note-item" data-id="${n.id}" onclick="viewNote(${n.id})">
          <div class="note-title">${escape(n.title)}</div>
          <div class="note-preview">${escape(n.body).slice(0, 60)}${n.body.length > 60 ? '…' : ''}</div>
          <button class="delete-btn" onclick="deleteNote(${n.id}, event)">×</button>
        </li>
      `).join('');
    }

    function viewNote(id) {
      const note = notes.find(n => n.id === id);
      if (!note) return;
      document.getElementById('compose').classList.add('hidden');
      document.getElementById('empty-state').classList.add('hidden');
      document.getElementById('note-view').classList.remove('hidden');
      document.getElementById('view-title').textContent = note.title;
      document.getElementById('view-body').textContent = note.body;
      document.getElementById('view-date').textContent = new Date(note.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
      // Highlight active item
      document.querySelectorAll('.note-item').forEach(el => el.classList.remove('active'));
      document.querySelector(`.note-item[data-id="${id}"]`)?.classList.add('active');
    }

    function escape(str) {
      return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    function showCompose() {
      document.getElementById('compose').classList.remove('hidden');
      document.getElementById('empty-state').classList.add('hidden');
      document.getElementById('note-view').classList.add('hidden');
      document.querySelectorAll('.note-item').forEach(el => el.classList.remove('active'));
      document.getElementById('title-input').focus();
    }

    function hideCompose() {
      document.getElementById('compose').classList.add('hidden');
      document.getElementById('title-input').value = '';
      document.getElementById('body-input').value = '';
      if (notes.length === 0) document.getElementById('empty-state').classList.remove('hidden');
    }

    async function saveNote() {
      const title = document.getElementById('title-input').value.trim();
      const body = document.getElementById('body-input').value.trim();
      if (!title || !body) return;
      await fetch('/api/notes', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title, body })
      });
      hideCompose();
      loadNotes();
    }

    async function deleteNote(id, e) {
      e.stopPropagation();
      await fetch('/api/notes', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id })
      });
      loadNotes();
    }

    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') hideCompose();
      if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') saveNote();
    });

    loadNotes();
  </script>
</body>
</html>
</client>

<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: system-ui, sans-serif; background: #f5f5f0; height: 100vh; overflow: hidden; }
.app { display: flex; height: 100vh; }
.sidebar { width: 260px; background: #1a1a1a; display: flex; flex-direction: column; flex-shrink: 0; }
.sidebar-header { display: flex; align-items: center; justify-content: space-between; padding: 20px 16px; border-bottom: 1px solid #2a2a2a; }
.sidebar-header h2 { color: #fff; font-size: 1rem; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; }
.new-btn { background: #0f6e56; color: white; border: none; border-radius: 6px; width: 28px; height: 28px; font-size: 1.2rem; cursor: pointer; display: flex; align-items: center; justify-content: center; }
.new-btn:hover { background: #085041; }
#note-list { flex: 1; overflow-y: auto; padding: 8px; }
.note-item { position: relative; padding: 12px; border-radius: 8px; cursor: pointer; margin-bottom: 4px; }
.note-item:hover { background: #2a2a2a; }
.note-title { color: #fff; font-size: 0.9rem; font-weight: 500; margin-bottom: 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; padding-right: 20px; }
.note-preview { color: #888; font-size: 0.78rem; line-height: 1.4; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.delete-btn { position: absolute; top: 10px; right: 8px; background: none; border: none; color: #555; font-size: 1rem; cursor: pointer; opacity: 0; transition: opacity 0.15s; }
.note-item:hover .delete-btn { opacity: 1; }
.delete-btn:hover { color: #e24b4a; }
.main { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
.compose { display: flex; flex-direction: column; height: 100%; padding: 24px; gap: 12px; }
.compose.hidden { display: none; }
#title-input { font-size: 1.4rem; font-weight: 600; border: none; background: transparent; outline: none; color: #1a1a1a; padding: 4px 0; }
#body-input { flex: 1; border: none; background: transparent; outline: none; font-size: 1rem; line-height: 1.7; resize: none; color: #333; font-family: inherit; }
.compose-actions { display: flex; gap: 8px; justify-content: flex-end; }
.cancel-btn { padding: 8px 16px; border: 1.5px solid #ddd; background: transparent; border-radius: 8px; cursor: pointer; font-size: 0.9rem; }
.save-btn { padding: 8px 16px; background: #0f6e56; color: white; border: none; border-radius: 8px; cursor: pointer; font-size: 0.9rem; }
.save-btn:hover { background: #085041; }
.empty-state { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 12px; color: #999; }
.empty-state.hidden { display: none; }
.empty-state p { font-size: 1rem; }
.note-item.active { background: #2a2a2a; }
.note-view { flex: 1; display: flex; flex-direction: column; padding: 32px; overflow-y: auto; gap: 12px; }
.note-view.hidden { display: none; }
.note-view-header { display: flex; flex-direction: column; gap: 6px; border-bottom: 1px solid #eee; padding-bottom: 16px; margin-bottom: 8px; }
#view-title { font-size: 1.6rem; font-weight: 700; color: #1a1a1a; }
#view-date { font-size: 0.8rem; color: #aaa; }
#view-body { font-size: 1rem; line-height: 1.8; color: #333; white-space: pre-wrap; }
</style>
